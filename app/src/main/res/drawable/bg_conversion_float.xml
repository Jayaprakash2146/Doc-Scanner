<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:left="2dp"
        android:top="6dp"
        android:right="2dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#50000000" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <item
        android:bottom="4dp"
        android:left="0dp"
        android:right="0dp"
        android:top="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#1A2A3E"
                android:centerColor="#243447"
                android:startColor="#2E4058"
                android:type="linear" />
            <corners android:radius="20dp" />
            <stroke
                android:width="1dp"
                android:color="@color/glass_stroke" />
        </shape>
    </item>
    <item
        android:bottom="4dp"
        android:left="0dp"
        android:right="0dp"
        android:top="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:endColor="#00FFFFFF"
                android:startColor="#33FFFFFF"
                android:type="linear" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</layer-list>
